generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TEACHER
  COUNSELLOR
  LEAD_ADMIN
}

enum ReferralStatus {
  SUBMITTED
  IN_REVIEW
  CASE_OPENED
  CLOSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum SessionType {
  INDIVIDUAL
  GROUP
  FAMILY
  CRISIS
}

enum AuditAction {
  REFERRAL_CREATED
  REFERRAL_TRIAGED
  CASE_CREATED
  NOTE_CREATED
  TASK_CREATED
  SESSION_NOTE_CREATED
}

model User {
  id           String     @id @default(cuid())
  clerkId      String?    @unique
  email        String     @unique
  name         String
  role         Role
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  referrals        Referral[] @relation("SubmittedReferrals")
  triagedReferrals Referral[] @relation("TriagedReferrals")
  assignedCases    Case[]
  assignedTasks    Task[]
  notes            Note[]
  sessionNotes     SessionNote[]
  auditLogs        AuditLog[]
}

model Referral {
  id            String         @id @default(cuid())
  studentName   String
  concern       String
  description   String
  status        ReferralStatus @default(SUBMITTED)
  riskLevel     RiskLevel?
  triageNotes   String?
  triagedById   String?
  triagedAt     DateTime?
  submittedById String
  submittedBy   User           @relation("SubmittedReferrals", fields: [submittedById], references: [id], onDelete: Cascade)
  triagedBy     User?          @relation("TriagedReferrals", fields: [triagedById], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Case          Case?
}

model Case {
  id            String         @id @default(cuid())
  referral      Referral       @relation(fields: [referralId], references: [id])
  referralId    String         @unique
  assignedTo    User           @relation(fields: [assignedToId], references: [id])
  assignedToId  String
  status        CaseStatus     @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         Task[]
  notes         Note[]
  sessionNotes  SessionNote[]
}

model Note {
  id        String   @id @default(cuid())
  content   String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionNote {
  id           String      @id @default(cuid())
  case         Case        @relation(fields: [caseId], references: [id])
  caseId       String
  sessionType  SessionType
  duration     Int
  sessionDate  DateTime
  summary      String
  observations String
  nextSteps    String
  author       User        @relation(fields: [authorId], references: [id])
  authorId     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Task {
  id            String         @id @default(cuid())
  title         String
  description   String?
  completed     Boolean        @default(false)
  dueDate       DateTime
  assignedToId  String
  assignedTo    User           @relation(fields: [assignedToId], references: [id])
  caseId        String
  case          Case           @relation(fields: [caseId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  details    String
  recordId   String
  recordType String
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  createdAt  DateTime    @default(now())
}